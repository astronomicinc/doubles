# ========================================================
# Doubles Web App — Environment Variables
# ========================================================
# Copy this file to .env.local and fill in your actual credentials
# .env.local is in .gitignore and will NOT be committed

# ========================================================
# SUPABASE (Database + Auth)
# ========================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ========================================================
# STRIPE (Payments)
# ========================================================
# Use test keys for development, live keys for production
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ========================================================
# RESEND (Email)
# ========================================================
RESEND_API_KEY=re_your_api_key_here

# ========================================================
# TWILIO (SMS)
# ========================================================
TWILIO_ACCOUNT_SID=AC_your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

# ========================================================
# INNGEST (Background Jobs)
# ========================================================
INNGEST_EVENT_KEY=your_event_key_here
INNGEST_SIGNING_KEY=your_signing_key_here

# ========================================================
# ANALYTICS
# ========================================================
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=doubles.singles

# ========================================================
# ERROR MONITORING
# ========================================================
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn_here

# ========================================================
# IMAGE HOSTING (Cloudinary or Vercel Blob)
# ========================================================
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name_here
CLOUDINARY_API_KEY=your_api_key_here
CLOUDINARY_API_SECRET=your_api_secret_here

# ========================================================
# APP SETTINGS
# ========================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Doubles
NODE_ENV=development

# ========================================================
# Note: DO NOT commit .env or .env.local to git
# These files contain sensitive credentials and are listed in .gitignore
