# Mailchimp API Configuration
# Get these values from your Mailchimp account dashboard
MAILCHIMP_API_KEY=your_api_key_here_starts_with_alphanumeric
MAILCHIMP_LIST_ID=your_list_id_here
MAILCHIMP_SERVER_PREFIX=us18

# Note: DO NOT commit .env or .env.local files to git
# Copy this file to .env.local and fill in your actual credentials
# .env.local is in .gitignore and will not be committed
